{
  "name": "@lucid/web",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build": "next build",
    "build:pages": "next build",
    "cloudflare:dev": "npx wrangler dev --config wrangler.jsonc --env local",
    "cloudflare:preview": "npx wrangler deploy --config wrangler.jsonc --env preview",
    "cloudflare:deploy": "npx wrangler deploy --config wrangler.jsonc",
    "dev": "next dev --port 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lucid/config": "workspace:*",
    "@lucid/shared-types": "workspace:*",
    "@lucid/ui": "workspace:*",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
